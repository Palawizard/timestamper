{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Timestamper",
  "version": "0.1.0",
  "identifier": "com.palawizard.timestamper",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Timestamper",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 560,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Save timestamp marks while you stream.",
    "longDescription": "Timestamper is a local desktop utility for starting stream timers, saving precise timestamp marks with global shortcuts, and reviewing completed streams.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
